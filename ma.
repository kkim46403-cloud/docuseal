import requests

# 你的机器人 Token
TOKEN = "8742865340:AAG0g2Bmrmwp08BofbcK15YWqaEljdLQhNA"

# 加上你的代理配置（如果电脑已经开了代理，把下面的地址改成你的代理端口，比如7890、10809）
proxies = {
    "http": "http://127.0.0.1:7890",
    "https": "http://127.0.0.1:7890"
}

def get_chat_id():
    url = f"https://api.telegram.org/bot{TOKEN}/getUpdates"
    try:
        # 如果没开代理，把 proxies=proxies 删掉
        resp = requests.get(url, proxies=proxies, timeout=10)
        data = resp.json()
        print("返回数据：", data)
        if data["ok"] and data["result"]:
            # 提取 chat id
            chat_id = data["result"][-1]["message"]["chat"]["id"]
            print(f"✅ 你的 Chat ID 是：{chat_id}")
        else:
            print("❌ 没拿到数据，先给机器人发一条 /start 消息再试")
    except Exception as e:
        print("❌ 请求失败，大概率是网络问题：", e)

if __name__ == "__main__":
    get_chat_id()
