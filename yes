name: 定时行情推送
on:
  workflow_dispatch:
  schedule:
    - cron: '*/30 * * * *'  # 每30分钟运行一次，可自行修改
jobs:
  run:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - name: Install dependencies
        run: pip install requests
      - name: Run script
        run: python main.py
